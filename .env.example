# Anthropic API key — Claude does all comprehension + writing
ANTHROPIC_API_KEY=

# Google Drive service account for Paperpile PDF access (same account as research-radio).
# Store the JSON file outside the repo or as ./credentials.json (gitignored); point here.
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# Google Drive folder ID where Paperpile stores PDFs
GOOGLE_DRIVE_FOLDER_ID=

# Slack incoming-webhook URL for posting new-paper digests to #toread.
# Leave blank to disable Slack posting (e.g. local runs).
SLACK_WEBHOOK_URL=
